---
import type { ImageMetadata } from 'astro'
import { Image } from 'astro:assets'

import type { iconsType } from 'astro-pure/types'
import { Icon } from 'astro-pure/user'

interface ToolItem {
  name: string
  icon: ImageMetadata
  frameClass?: string
  imageClass?: string
}

interface ToolGroup {
  title: string
  icon: iconsType
  description: string
  items: readonly ToolItem[]
}

interface Props {
  groups: readonly ToolGroup[]
}

const { groups } = Astro.props
---

<div class='not-prose space-y-5'>
  {
    groups.map((group) => (
      <section class='rounded-3xl border border-border/70 bg-gradient-to-b from-card to-muted/35 p-5 shadow-sm'>
        <div class='flex items-start gap-4'>
          <div class='flex size-11 shrink-0 items-center justify-center rounded-2xl bg-background text-primary shadow-sm ring-1 ring-border/60'>
            <Icon class='size-6' name={group.icon} />
          </div>
          <div class='space-y-1'>
            <h3 class='text-lg font-semibold text-foreground'>{group.title}</h3>
            <p class='text-sm leading-6 text-muted-foreground'>{group.description}</p>
          </div>
        </div>

        <div class='mt-5 grid gap-3 sm:grid-cols-2 xl:grid-cols-3'>
          {
            group.items.map((tool) => (
              <div class='flex min-h-[4.5rem] items-center gap-3 rounded-2xl border border-border/70 bg-background/80 px-4 py-3 shadow-sm'>
                <div
                  class:list={[
                    'flex size-14 shrink-0 items-center justify-center overflow-hidden rounded-[1.15rem] ring-1 ring-black/6 shadow-[inset_0_1px_0_rgba(255,255,255,0.7)] dark:ring-white/8 dark:shadow-none',
                    tool.frameClass ?? 'bg-white/95 dark:bg-zinc-950/90'
                  ]}
                >
                  <Image
                    src={tool.icon}
                    alt={`${tool.name} icon`}
                    width={48}
                    height={48}
                    class:list={[
                      'object-contain',
                      tool.imageClass ?? 'size-10'
                    ]}
                  />
                </div>
                <p class='text-sm font-medium text-foreground'>{tool.name}</p>
              </div>
            ))
          }
        </div>
      </section>
    ))
  }
</div>
