---
import { Button } from 'astro-pure/user'
import PageLayout from '@/layouts/CommonPage.astro'
import Substats from '@/components/about/Substats.astro'
import ToolSection from '@/components/about/ToolSection.astro'
import chrome from '@/assets/tools/chrome.svg'
import edge from '@/assets/tools/edge-cropped.png'
import typora from '@/assets/tools/typora.png'
import vscode from '@/assets/tools/vscode.svg'
import idea from '@/assets/tools/idea.svg'
import goland from '@/assets/tools/goland.svg'
import obsidian from '@/assets/tools/obsidian.png'
import windows11 from '@/assets/tools/windows11.svg'
import ubuntu from '@/assets/tools/ubuntu.svg'
import codex from '@/assets/tools/codex.svg'
import drawio from '@/assets/tools/drawio.png'

type ToolIcon =
  | typeof chrome
  | typeof edge
  | typeof typora
  | typeof vscode
  | typeof idea
  | typeof goland
  | typeof obsidian
  | typeof windows11
  | typeof ubuntu
  | typeof codex
  | typeof drawio

const tool = (name: string, icon: ToolIcon, frameClass: string, imageClass: string) => ({
  name,
  icon,
  frameClass,
  imageClass
})

const headings = [
  { depth: 2, slug: 'education', text: 'Education' },
  { depth: 2, slug: 'direction', text: 'Direction' },
  { depth: 2, slug: 'tools', text: 'Tools' },
  { depth: 2, slug: 'social', text: 'Social' },
  { depth: 2, slug: 'about-blog', text: 'About Blog' }
]

const toolGroups = [
  {
    title: 'Productivity',
    icon: 'list',
    description: '主要用于信息获取、文档整理、笔记沉淀与结构化表达。',
    items: [
      tool('Chrome', chrome, 'bg-[#eef4ff] dark:bg-[#18304a]', 'size-[2.8rem]'),
      tool('Edge', edge, 'bg-[#eefbff] dark:bg-[#113546]', 'size-[2.75rem]'),
      tool(
        'Typora',
        typora,
        'bg-transparent ring-transparent shadow-none dark:ring-transparent dark:bg-transparent',
        'size-[2.55rem]'
      ),
      tool('Obsidian', obsidian, 'bg-[#f5efff] dark:bg-[#2f2245]', 'size-[2.4rem]'),
      tool('draw.io', drawio, 'bg-[#fff2e8] dark:bg-[#4a2d18]', 'size-[2.55rem]')
    ]
  },
  {
    title: 'Development',
    icon: 'computer',
    description: '围绕日常编码、工程实现与辅助开发所使用的核心工具。',
    items: [
      tool('VS Code', vscode, 'bg-[#eef7ff] dark:bg-[#15314a]', 'size-[2.35rem]'),
      tool('IntelliJ IDEA', idea, 'bg-[#fff0f5] dark:bg-[#42202e]', 'size-[2.45rem]'),
      tool('GoLand', goland, 'bg-[#ecfff8] dark:bg-[#163b31]', 'size-[2.45rem]'),
      tool('Codex', codex, 'bg-[#f3f4f6] dark:bg-[#22252b]', 'size-[2.1rem]')
    ]
  },
  {
    title: 'Environment',
    icon: 'earth',
    description: '当前主要使用的操作系统与开发运行环境。',
    items: [
      tool('Windows 11', windows11, 'bg-[#eef4ff] dark:bg-[#173152]', 'size-[2.3rem]'),
      tool('Ubuntu 22.04', ubuntu, 'bg-[#fff1eb] dark:bg-[#452319]', 'size-[2.35rem]')
    ]
  }
] as const
---

<PageLayout title='About' {headings}>
  <p>
    你好，我是 Spark，一名正在学习计算机相关方向的工科生。这一页主要整理我的学习背景、
    当前关注的技术方向，以及这个博客的基本定位。
  </p>
  <p>
    平时我更愿意把时间放在能够长期积累的事情上，例如写代码、理解系统、完成项目，以及整理问题复盘和学习笔记。
    这些内容也构成了我持续记录和维护这个博客的基础。
  </p>

  <h2 id='education'>Education</h2>
  <p>目前就读于西南大学，学习内容主要围绕计算机基础与工程实践展开。</p>
  <p>
    现阶段，我会把课程学习、项目练习和实际问题放在一起理解，希望在持续动手的过程中逐步形成更稳定的技术判断和工程感受。
  </p>

  <h2 id='direction'>Direction</h2>
  <ul>
    <li>主力技术栈是 Java，目前主要关注后端基础、工程能力和项目实现。</li>
    <li>也在继续学习 Go，希望逐步理解不同语言在后端开发中的思路差异和适用场景。</li>
    <li>这个博客会持续记录学习过程、项目实践和问题复盘，作为长期更新的个人技术记录。</li>
  </ul>

  <h2 id='tools'>Tools</h2>
  <p>
    下面这些工具构成了我当前较为稳定的一套学习、开发与记录工作流。
  </p>
  <ToolSection groups={toolGroups} />

  <h2 id='social'>Social</h2>
  <p>
    目前公开整理中的主要社交出口就是 GitHub。后续如果有新的公开平台，也会在这里补充。
  </p>
  <Substats
    stats={[
      {
        platform: 'GitHub',
        icon: 'github',
        link: 'https://github.com/Atingaii',
        text: 'followers',
        api: 'github/Atingaii'
      }
    ]}
  />

  <h2 id='about-blog'>About Blog</h2>
  <p>
    这个博客主要记录我在学习和项目实践中的阶段性内容，包括技术笔记、问题整理和过程复盘。
  </p>
  <p>
    我会继续把它当作一份长期维护的个人技术记录，随着学习进度和项目经历逐步补充和完善。
  </p>
  <Button title='查看项目' class='w-fit' href='/projects' variant='ahead' />
</PageLayout>
